# ========================
# Backend (.env in backend/)
# ========================
DATABASE_URL=postgresql://user:password@localhost:5432/smartline

JWT_SECRET=your-jwt-secret-here
JWT_REFRESH_SECRET=your-jwt-refresh-secret-here

R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_ACCESS_KEY=your-r2-access-key
R2_SECRET_KEY=your-r2-secret-key
R2_BUCKET=smartline-products
R2_PUBLIC_URL=https://cdn.smartline.com.ua

NOVA_POSHTA_KEY=your-nova-poshta-api-key

TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id

MONOBANK_TOKEN=your-monobank-token
MONOBANK_WEBHOOK_SECRET=your-monobank-webhook-secret

RESEND_API_KEY=your-resend-api-key
RESEND_FROM=noreply@smartline.com.ua

FRONTEND_URL=http://localhost:3000

# ========================
# Frontend (.env.local in frontend/)
# ========================
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
NEXT_PUBLIC_META_PIXEL=XXXXXXXXXX
